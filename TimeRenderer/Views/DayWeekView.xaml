<UserControl x:Class="TimeRenderer.Views.DayWeekView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:TimeRenderer.Helpers"
             xmlns:controls="clr-namespace:TimeRenderer.Controls">
    <!--
        日/週ビュー（曜日ヘッダー・終日イベント・時間グリッド）。
        コンバーター等の共有リソースは Themes/Styles.xaml（アプリレベル）で定義している。
        DataContext は MainWindow から継承した MainViewModel。
        表示・非表示（月モードで隠す）は MainWindow 側でこのコントロール自体に設定する。
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー行（曜日） + 終日イベントエリア -->
        <StackPanel Grid.Row="0" Background="{DynamicResource SurfaceBrush}">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- スクロールバー幅分のスペーサー（スケジュール領域との列幅整合用） -->
                    <Border Grid.Column="2" Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                    
                    <!-- 日付ヘッダー -->
                    <controls:TransitioningContentControl Grid.Column="1" 
                                                          Content="{Binding CurrentDate}" 
                                                          TransitionDirection="{Binding TransitionDirection}"
                                                          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <controls:TransitioningContentControl.ContentTemplate>
                            <DataTemplate>
                                <ItemsControl Height="30">
                                    <ItemsControl.ItemsSource>
                                        <MultiBinding Converter="{StaticResource DateToVisibleDaysConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </ItemsControl.ItemsSource>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource DateToBackgroundBrushConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                                <TextBlock Text="{Binding StringFormat='MM/dd (ddd)'}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" 
                                                           Language="ja-JP">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource DayOfWeekToBrushConverter}">
                                                            <Binding />
                                                            <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </controls:TransitioningContentControl.ContentTemplate>
                    </controls:TransitioningContentControl>
                </Grid>
            </Border>

            <!-- 終日イベントエリア -->
            <Grid MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- スクロールバー幅分のスペーサー（スケジュール領域との列幅整合用） -->
                <Border Grid.Column="2" Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource BackgroundBrush}">
                    <TextBlock Text="終日" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,4,8,4" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <controls:TransitioningContentControl Grid.Column="1" 
                                                      Content="{Binding CurrentDate}" 
                                                      TransitionDirection="{Binding TransitionDirection}"
                                                      Height="{Binding AllDayPanelHeight}"
                                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <controls:TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding DataContext.AllDayItems, RelativeSource={RelativeSource AncestorType=Window}}" 
                                          Margin="0,2">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BackgroundColor}" CornerRadius="6" Padding="6,2" Height="24" Opacity="0.95" BorderBrush="White" BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ScheduleItem_MouseLeftButtonDown">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                            </Border.Effect>
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="編集" Click="EditMenuItem_Click"/>
                                                    <MenuItem Header="この内容で記録開始" Click="ResumeRecordingMenuItem_Click"/>
                                                    <MenuItem Header="削除" Click="DeleteMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Visibility">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPageVisibilityConverter}" FallbackValue="Collapsed">
                                                    <Binding Path="StartTime" />
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Top" Value="{Binding ColumnIndex, Converter={StaticResource IndexToTopMarginConverter}}"/>
                                         <!-- X座標 (Canvas.Left) -->
                                        <Setter Property="Canvas.Left">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPagePositionConverter}">
                                                    <Binding Path="StartTime" />
                                                    <Binding Source="{StaticResource Zero}" /> <!-- ColumnIndex = 0 -->
                                                    <Binding Source="{StaticResource Zero}" /> <!-- MaxColumnIndex = 0 -->
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    <Binding Path="IsAllDay" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <!-- 幅 (Width) -->
                                        <Setter Property="Width">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPagePositionConverter}" ConverterParameter="WIDTH">
                                                    <Binding Path="StartTime" />
                                                    <Binding Source="{StaticResource Zero}" /> <!-- ColumnIndex = 0 -->
                                                    <Binding Source="{StaticResource Zero}" /> <!-- MaxColumnIndex = 0 -->
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    <Binding Path="IsAllDay" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </DataTemplate>
                    </controls:TransitioningContentControl.ContentTemplate>
                </controls:TransitioningContentControl>
            </Grid>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"/>
        </StackPanel>

        <!-- スケジュール領域 -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Focusable="True" PreviewKeyDown="ScheduleView_PreviewKeyDown"
                      helpers:ScrollViewerHelper.EnableMiddleButtonScroll="True">
            <Grid Height="{Binding ScheduleGridHeight}" Background="{DynamicResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 時刻ラベル -->
                <ItemsControl ItemsSource="{Binding TimeLabels}" Grid.Column="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                <TextBlock Text="{Binding}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,4,8,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <controls:TransitioningContentControl Grid.Column="1" 
                                                      Content="{Binding CurrentDate}" 
                                                      TransitionDirection="{Binding TransitionDirection}"
                                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <controls:TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <!-- Background=Transparent: 空白部分のクリック・ドラッグ（予定追加）をヒットテスト可能にする -->
                            <Grid Background="Transparent"
                                  MouseLeftButtonDown="ScheduleBackground_MouseLeftButtonDown"
                                  MouseMove="ScheduleBackground_MouseMove"
                                  MouseLeftButtonUp="ScheduleBackground_MouseLeftButtonUp">
                                <!-- 背景グリッド（縦：日付区切り） -->
                                <ItemsControl>
                                    <ItemsControl.ItemsSource>
                                        <MultiBinding Converter="{StaticResource DateToVisibleDaysConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </ItemsControl.ItemsSource>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 縦線 -->
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource DateToBackgroundBrushConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 背景グリッド（横：時間区切り） -->
                                <ItemsControl ItemsSource="{Binding DataContext.TimeLabels, RelativeSource={RelativeSource AncestorType=Window}}">
                                     <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                     <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- スケジュールアイテム -->
                                <ItemsControl x:Name="ScheduleItemsControl" ItemsSource="{Binding DataContext.StandardItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <!-- ClipToBounds: 表示時間範囲外・日またぎのアイテムがグリッド外へはみ出して描画されるのを防ぐ -->
                                            <Canvas x:Name="ScheduleCanvas" ClipToBounds="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPageVisibilityConverter}" FallbackValue="Collapsed">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Top">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                        <Binding Path="StartTime"/>
                                                        <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            
                                            <!-- X座標 (Canvas.Left) -->
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="ColumnIndex" />
                                                        <Binding Path="MaxColumnIndex" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Path="IsAllDay" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <!-- 幅 (Width) -->
                                            <Setter Property="Width">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}" ConverterParameter="WIDTH">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="ColumnIndex" />
                                                        <Binding Path="MaxColumnIndex" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Path="IsAllDay" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            
                                            <!-- アニメーション用 -->
                
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid x:Name="ItemRoot" Cursor="Hand" MouseLeftButtonDown="ScheduleItem_MouseLeftButtonDown" Margin="1,0,1,0"
                                                  Height="{Binding DurationHours, Converter={StaticResource DurationToHeightConverter}, ConverterParameter=ADD_EXTENSION}"
                                                  ToolTip="{Binding Item.ToolTipText}"
                                                  ToolTipService.InitialShowDelay="250"
                                                  ToolTipService.ShowDuration="20000">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="編集" Click="EditMenuItem_Click"/>
                                                    <MenuItem Header="この内容で記録開始" Click="ResumeRecordingMenuItem_Click"/>
                                                        <MenuItem Header="削除" Click="DeleteMenuItem_Click"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>

                                                <!-- 背景と形状 -->
                                                <Path x:Name="ItemShape" Fill="{Binding BackgroundColor}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1" Opacity="0.9">
                                                    <Path.Effect>
                                                         <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                                                    </Path.Effect>
                                                    <Path.Data>
                                                        <MultiBinding Converter="{StaticResource LShapeGeometryConverter}">
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Path.Data>
                                                </Path>

                                                <!-- コンテンツ (下の15分部分(約15px)にはテキストが被らないようにマージン設定) -->
                                                <!-- 文字色は背景の輝度から決める（濃いカテゴリ色・ダークモードでも読めるように） -->
                                                <Border Padding="8,6" Margin="0,0,0,15" VerticalAlignment="Top">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}}"/>
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}, ConverterParameter=Muted}"/>
                                                        <!-- 日またぎで分割されたセグメントでも、元アイテムの本来の時間帯を表示する -->
                                                        <TextBlock FontSize="10" Margin="0,2,0,0"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}, ConverterParameter=Muted}">
                                                            <Run Text="{Binding Item.StartTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding Item.EndTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <DataTemplate.Triggers>
                                                <!-- ホバー：不透明度と枠線を上げて、掴める対象だと分かるようにする -->
                                                <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemShape" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ItemShape" Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                                </Trigger>
                                                <!-- 選択中：太い枠線で示す（キーボード操作の現在位置） -->
                                                <DataTrigger Binding="{Binding Item.IsSelected}" Value="True">
                                                    <Setter TargetName="ItemShape" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ItemShape" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Setter TargetName="ItemShape" Property="StrokeThickness" Value="2.5"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!--
                                    出勤・退勤マーカー。
                                    予定バーと同じ「箱」で描くと作業記録と混ざるため、
                                    その日の列の幅いっぱいに横線とラベルだけを引く。
                                    位置計算は予定バーと同じコンバーターを共用する（Time を StartTime として渡す）。
                                -->
                                <ItemsControl ItemsSource="{Binding DataContext.WorkDayMarkers, RelativeSource={RelativeSource AncestorType=Window}}"
                                              IsHitTestVisible="False">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas ClipToBounds="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPageVisibilityConverter}" FallbackValue="Collapsed">
                                                        <Binding Path="Time" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Top">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                        <Binding Path="Time"/>
                                                        <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}">
                                                        <Binding Path="Time" />
                                                        <Binding Source="{StaticResource Zero}" /> <!-- ColumnIndex -->
                                                        <Binding Source="{StaticResource Zero}" /> <!-- MaxColumnIndex -->
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Source="{StaticResource FalseValue}" /> <!-- IsAllDay -->
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Width">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}" ConverterParameter="WIDTH">
                                                        <Binding Path="Time" />
                                                        <Binding Source="{StaticResource Zero}" />
                                                        <Binding Source="{StaticResource Zero}" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Source="{StaticResource FalseValue}" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 線の上にラベルが乗るよう、線を下端に置いて上へ吹き出す -->
                                            <Grid Height="18" VerticalAlignment="Top" RenderTransformOrigin="0,0">
                                                <Grid.RenderTransform>
                                                    <TranslateTransform Y="-16"/> <!-- 線を Canvas.Top（=時刻の位置）に合わせる -->
                                                </Grid.RenderTransform>
                                                <Border x:Name="MarkerLine" VerticalAlignment="Bottom" Height="2"
                                                        Background="{DynamicResource WorkStartBrush}" Opacity="0.9"/>
                                                <Border x:Name="MarkerChip" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,1"
                                                        Background="{DynamicResource WorkStartBrush}" CornerRadius="3" Padding="5,1" Opacity="0.95">
                                                    <TextBlock Text="{Binding Label}" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <!-- 退勤は色を変える（同じ色だと1日に2本の線が並んだとき区別できない） -->
                                                <DataTrigger Binding="{Binding IsStart}" Value="False">
                                                    <Setter TargetName="MarkerLine" Property="Background" Value="{DynamicResource WorkEndBrush}"/>
                                                    <Setter TargetName="MarkerChip" Property="Background" Value="{DynamicResource WorkEndBrush}"/>
                                                </DataTrigger>
                                                <!-- 自動で入った退勤は控えめに（あとで直す前提の値なので、確定した記録と同じ強さで見せない） -->
                                                <DataTrigger Binding="{Binding IsAuto}" Value="True">
                                                    <Setter TargetName="MarkerLine" Property="Opacity" Value="0.55"/>
                                                    <Setter TargetName="MarkerChip" Property="Opacity" Value="0.75"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 現在時刻インジケーター -->
                                <Canvas ClipToBounds="True">
                                    <Border BorderBrush="{DynamicResource DangerBrush}" BorderThickness="0,2,0,0" Height="2" 
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}">
                                        <Canvas.Top>
                                            <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                <Binding Path="DataContext.CurrentTime" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Canvas.Top>
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource DangerColor}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <!-- 現在時刻の赤丸 -->
                                    <Ellipse Fill="{DynamicResource DangerBrush}" Width="8" Height="8" Canvas.Left="-4"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Canvas.Top>
                                            <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                <Binding Path="DataContext.CurrentTime" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Canvas.Top>
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform Y="-4"/> <!-- ライン上に中心を合わせる -->
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Canvas>
                                
                            </Grid>
                        </DataTemplate>
                    </controls:TransitioningContentControl.ContentTemplate>
                </controls:TransitioningContentControl>
                
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
