<Window x:Class="TimeRenderer.Views.Dialogs.RoutineEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="定期予定の編集" Height="680" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル（手入力＋ドロップダウン候補） -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="タイトル" Style="{StaticResource FieldLabelStyle}"/>
            <ComboBox x:Name="TitleCombo" IsEditable="True" FontSize="14" Padding="6,6"
                      IsTextSearchEnabled="False" MaxDropDownHeight="240"/>
        </StackPanel>

        <!-- 繰り返す曜日 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="繰り返す曜日" Style="{StaticResource FieldLabelStyle}"/>
            <WrapPanel>
                <CheckBox x:Name="MonCheck" Content="月" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="TueCheck" Content="火" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="WedCheck" Content="水" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="ThuCheck" Content="木" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="FriCheck" Content="金" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="SatCheck" Content="土" Margin="0,4,14,0" VerticalContentAlignment="Center"/>
                <CheckBox x:Name="SunCheck" Content="日" Margin="0,4,0,0" VerticalContentAlignment="Center"/>
            </WrapPanel>
        </StackPanel>

        <!-- 開始時刻 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="開始時刻" Style="{StaticResource FieldLabelStyle}"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="StartHourCombo" Width="80" FontSize="14" Padding="6,6"/>
                <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" FontSize="16" FontWeight="Bold"/>
                <ComboBox x:Name="StartMinuteCombo" Width="80" FontSize="14" Padding="6,6"/>
            </StackPanel>
        </StackPanel>

        <!-- 終了時刻 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,14">
            <TextBlock Text="終了時刻" Style="{StaticResource FieldLabelStyle}"/>
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="EndHourCombo" Width="80" FontSize="14" Padding="6,6"/>
                <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0" FontSize="16" FontWeight="Bold"/>
                <ComboBox x:Name="EndMinuteCombo" Width="80" FontSize="14" Padding="6,6"/>
            </StackPanel>
        </StackPanel>

        <!-- カテゴリ -->
        <StackPanel Grid.Row="4" Margin="0,0,0,14">
            <TextBlock Text="カテゴリ" Style="{StaticResource FieldLabelStyle}"/>
            <ComboBox x:Name="ColorCombo" Width="200" HorizontalAlignment="Left" FontSize="14" Padding="6,6">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="20" Height="20" Background="{Binding Brush}" CornerRadius="3" Margin="0,0,8,0" BorderBrush="#CCCCCC" BorderThickness="1"/>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <!-- 記録開始の挙動 -->
        <StackPanel Grid.Row="5" Margin="0,0,0,8">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,12"/>
            <CheckBox x:Name="AutoStartCheckBox" Content="予定時刻になったら自動で記録を開始する" VerticalContentAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="オフの場合は開始時刻にリマインダー通知を表示します（記録開始ボタンをワンクリックで押せます）"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <CheckBox x:Name="ForceStartCheckBox" Content="記録中でも強制的に開始する" VerticalContentAlignment="Center" Margin="16,0,0,4"
                      IsEnabled="{Binding IsChecked, ElementName=AutoStartCheckBox}"/>
            <TextBlock Text="オンの場合、自動開始の時刻に別の記録中でも現在の記録を停止・保存して開始します"
                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="16,0,0,12"/>
            <CheckBox x:Name="EnabledCheckBox" Content="この定期予定を有効にする" VerticalContentAlignment="Center" IsChecked="True"/>
        </StackPanel>

        <!-- ボタン -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="キャンセル" Width="100" Height="36" Margin="0,0,12,0"
                    Click="CancelButton_Click" Style="{StaticResource BaseButtonStyle}"/>
            <Button Content="OK" Width="100" Height="36"
                    Click="OkButton_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
