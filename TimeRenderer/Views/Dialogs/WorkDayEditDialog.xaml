<Window x:Class="TimeRenderer.Views.Dialogs.WorkDayEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="勤務時間の編集" Height="300" Width="360"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="ToolWindow"
        Background="{DynamicResource BackgroundBrush}">
    <!--
        出勤・退勤の時刻をあとから直すためのダイアログ。
        押し忘れた日の追加にも使うため、日付も変更できるようにしている。
    -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 日付 -->
        <TextBlock Grid.Row="0" Text="勤務日:" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"/>
        <DatePicker x:Name="DatePickerControl" Grid.Row="1" SelectedDate="{Binding SelectedDate}"
                    FontSize="14" Margin="0,0,0,16"/>

        <!-- 出勤・退勤 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="出勤:" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="StartTextBox" Text="{Binding StartText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="6,6"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="退勤:" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,6"/>
                <TextBox x:Name="EndTextBox" Text="{Binding EndText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="6,6"/>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" FontSize="11" TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Text="時刻は 9:05 のように入力します。退勤を空にすると「勤務中」として扱います（当日のみ）。退勤が出勤より前の場合は翌日として記録します。"/>

        <!-- 入力エラー（保存を押したときだけ出す） -->
        <TextBlock x:Name="ErrorText" Grid.Row="4" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0"
                   VerticalAlignment="Top" Foreground="{DynamicResource DangerBrush}"
                   Visibility="Collapsed"/>

        <!-- ボタン -->
        <Grid Grid.Row="5">
            <Button x:Name="DeleteButton" Content="削除" Click="DeleteButton_Click" Width="80"
                    HorizontalAlignment="Left" Style="{StaticResource BaseButtonStyle}"
                    Foreground="{DynamicResource DangerBrush}" BorderBrush="{DynamicResource DangerBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="保存" IsDefault="True" Click="SaveButton_Click" Width="90" Margin="0,0,10,0"
                        Style="{StaticResource PrimaryButtonStyle}"/>
                <Button Content="キャンセル" IsCancel="True" Width="90" Style="{StaticResource BaseButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
