<Window x:Class="TimeRenderer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TimeRenderer"
        xmlns:helpers="clr-namespace:TimeRenderer.Helpers"
        xmlns:conv="clr-namespace:TimeRenderer.Converters"
        xmlns:controls="clr-namespace:TimeRenderer.Controls"
        xmlns:views="clr-namespace:TimeRenderer.Views"
        xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Background="{DynamicResource BackgroundBrush}"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Title="TimeRenderer" Height="700" Width="1100"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDownForUndo">
    <Window.Resources>
        <!-- PixelsPerHour は LayoutConstants.PixelsPerHour を既定値として使う（XAML側で上書きしない） -->
        <conv:TimeToPositionConverter x:Key="TimeToPositionConverter"/>
        <conv:DurationToHeightConverter x:Key="DurationToHeightConverter"/>
        <conv:DateToPagePositionConverter x:Key="DateToPagePositionConverter"/>
        <conv:DateToPageVisibilityConverter x:Key="DateToPageVisibilityConverter"/>
        <conv:IndexToTopMarginConverter x:Key="IndexToTopMarginConverter" ItemHeight="24"/>
        <conv:DateToVisibleDaysConverter x:Key="DateToVisibleDaysConverter"/>
        <sys:Int32 x:Key="Zero">0</sys:Int32>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:LShapeGeometryConverter x:Key="LShapeGeometryConverter"/>

        <Style TargetType="ListBoxItem" x:Key="TimeLabelStyle">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Height="{TemplateBinding Height}" BorderBrush="LightGray" BorderThickness="0,1,0,0">
                            <ContentPresenter Margin="0,5,5,0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmented Control RadioButton Style -->
        <Style x:Key="SegmentedRadioButtonBase" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding Tag}"> <!-- TagプロパティをCornerRadiusとして悪用 -->
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimarySubtleBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource PrimaryDarkBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SegmentedLeftStyle" TargetType="RadioButton" BasedOn="{StaticResource SegmentedRadioButtonBase}">
            <Setter Property="Tag" Value="4,0,0,4"/> <!-- Left Corner -->
            <Setter Property="BorderThickness" Value="1,1,0,1"/>
        </Style>

        <Style x:Key="SegmentedMiddleStyle" TargetType="RadioButton" BasedOn="{StaticResource SegmentedRadioButtonBase}">
            <Setter Property="Tag" Value="0,0,0,0"/> <!-- No Corner -->
            <Setter Property="BorderThickness" Value="1,1,0,1"/>
            <Setter Property="Margin" Value="-1,0,0,0"/>
        </Style>

        <Style x:Key="SegmentedRightStyle" TargetType="RadioButton" BasedOn="{StaticResource SegmentedRadioButtonBase}">
            <Setter Property="Tag" Value="0,4,4,0"/> <!-- Right Corner -->
            <Setter Property="BorderThickness" Value="1,1,1,1"/> <!-- 境界線が太くなるのを防ぐため左側も描画し、重なりを考慮するか、0,1,1,1にするか。ここでは左ボーダーありにして、並べたときに重なるようにマージン調整する手もあるが、シンプルに 1,1,1,1 で左隣のボーダーと重なるように Margin="-1,0,0,0" するのが綺麗に見える。 -->
            <Setter Property="Margin" Value="-1,0,0,0"/>
        </Style>
        <!-- 統計ビュー：カテゴリ別横棒グラフ用スタイル -->
        <Style x:Key="StatsBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="4"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                    CornerRadius="4" HorizontalAlignment="Left" Margin="1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <conv:DayOfWeekToBrushConverter x:Key="DayOfWeekToBrushConverter"/>
        <conv:DateToBackgroundBrushConverter x:Key="DateToBackgroundBrushConverter"/>
        <conv:BrushToContrastTextConverter x:Key="BrushToContrastTextConverter"/>

        <!-- 検索結果1行分のボタン（行全体がクリック可能・ホバーで強調） -->
        <Style x:Key="SearchResultButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimarySubtleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/> <!-- Memo Panel -->
        </Grid.ColumnDefinitions>

        <!-- ツールバー + 定期予定リマインダー通知（縦に積むための StackPanel） -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="2">
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左側：追加・ナビゲーション・日付 -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Button Content="＋ 追加" Click="AddButton_Click" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>

                    <!-- 取り消し / やり直し（予定の追加・削除・編集・ドラッグが対象） -->
                    <Button Content="&#xE7A7;" Command="{Binding UndoCommand}" Style="{StaticResource BaseButtonStyle}"
                            FontFamily="Segoe MDL2 Assets" FontSize="12" Width="32" Padding="0" Margin="0,0,4,0"
                            ToolTip="{Binding UndoToolTip}"/>
                    <Button Content="&#xE7A6;" Command="{Binding RedoCommand}" Style="{StaticResource BaseButtonStyle}"
                            FontFamily="Segoe MDL2 Assets" FontSize="12" Width="32" Padding="0" Margin="0,0,16,0"
                            ToolTip="{Binding RedoToolTip}"/>

                    <Button Content="今日" Command="{Binding TodayCommand}" Style="{StaticResource BaseButtonStyle}" Margin="0,0,8,0"/>
                    <Button Content="&#xE76B;" Command="{Binding PreviousCommand}" Style="{StaticResource BaseButtonStyle}"
                            FontFamily="Segoe MDL2 Assets" FontSize="11" Width="32" Padding="0" Margin="0,0,4,0" ToolTip="前へ"/>
                    <Button Content="&#xE76C;" Command="{Binding NextCommand}" Style="{StaticResource BaseButtonStyle}"
                            FontFamily="Segoe MDL2 Assets" FontSize="11" Width="32" Padding="0" Margin="0,0,12,0" ToolTip="次へ"/>

                    <TextBlock Text="{Binding DateDisplay}" VerticalAlignment="Center" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 中央（右寄せ）：検索 + 色フィルタ -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12,0,0,0">

                    <!-- 検索トグル（クリックで検索フライアウトを開く） -->
                    <ToggleButton x:Name="SearchToggle" Style="{StaticResource IconToggleButtonStyle}" ToolTip="検索"
                                  Checked="SearchToggle_Checked"
                                  PreviewMouseLeftButtonDown="SearchToggle_PreviewMouseLeftButtonDown"
                                  VerticalAlignment="Center" Content="&#xE721;"/>

                    <!-- 色フィルタ トグル -->
                    <ToggleButton x:Name="FilterToggle" Margin="2,0,0,0" VerticalAlignment="Center"
                                  PreviewMouseLeftButtonDown="FilterToggle_PreviewMouseLeftButtonDown"
                                  Style="{StaticResource IconToggleButtonStyle}" ToolTip="カテゴリフィルタ">
                        <Grid Width="32" Height="32">
                            <TextBlock Text="&#xE71C;" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Ellipse Width="7" Height="7" Fill="{DynamicResource PrimaryBrush}"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,4,0"
                                     Visibility="{Binding IsColorFilterActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </ToggleButton>

                    <!-- 検索フライアウト（入力＋結果一覧の一体型・トグル右端に揃えて表示） -->
                    <Popup x:Name="SearchFlyout" PlacementTarget="{Binding ElementName=SearchToggle}" Placement="Custom"
                           IsOpen="{Binding IsChecked, ElementName=SearchToggle, Mode=TwoWay}" StaysOpen="False"
                           AllowsTransparency="True" PopupAnimation="Fade"
                           Closed="SearchFlyout_Closed">
                        <Border Width="340" MaxHeight="480" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                                PreviewKeyDown="SearchFlyout_PreviewKeyDown">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 検索入力 -->
                                <Border Grid.Row="0" Height="34" CornerRadius="6" Margin="10,10,10,8"
                                        Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                        <TextBox x:Name="SearchTextBox" Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                                 FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <!-- プレースホルダ -->
                                        <TextBlock Grid.Column="1" Text="タイトル・内容を検索" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"
                                                   IsHitTestVisible="False" VerticalAlignment="Center" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- クリア -->
                                        <Button Grid.Column="2" Content="✕" Command="{Binding ClearSearchCommand}"
                                                Width="22" Height="22" Margin="0,0,4,0"
                                                Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- 件数（クエリ入力時のみ表示） -->
                                <Border Grid.Row="1" Padding="12,0,12,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SearchResultCountText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Border>

                                <!-- 結果一覧 -->
                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding HasSearchResults, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SearchResultButtonStyle}"
                                                        Command="{Binding DataContext.JumpToSearchResultCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Click="SearchResultButton_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="10" Height="10" CornerRadius="2" Background="{Binding Brush}"
                                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                                Margin="0,3,8,0" VerticalAlignment="Top"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Content}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                                                                       Visibility="{Binding HasContent, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                <TextBlock Text="{Binding DateText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}"/>
                                                                <TextBlock Text="{Binding TimeText}" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="8,0,0,0"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Popup>

                    <!-- 色フィルタ ポップアップ（トグル右端に揃えて表示） -->
                    <Popup x:Name="FilterPopup" PlacementTarget="{Binding ElementName=FilterToggle}" Placement="Custom"
                           IsOpen="{Binding IsChecked, ElementName=FilterToggle, Mode=TwoWay}" StaysOpen="False" AllowsTransparency="True"
                           PopupAnimation="Fade"
                           Closed="FilterPopup_Closed">
                        <Border Width="240" MaxHeight="400" Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                    <TextBlock Text="表示するカテゴリ" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="290">
                                    <ItemsControl ItemsSource="{Binding Categories}" Margin="6">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsFilterEnabled}" Margin="6,4" Cursor="Hand" VerticalContentAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="14" Height="14" CornerRadius="3" Background="{Binding Brush}"
                                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="2,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                                <Button Grid.Row="2" Content="すべて表示" Command="{Binding ResetColorFilterCommand}"
                                        Style="{StaticResource BaseButtonStyle}" Margin="10" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>

                <!-- 右側：記録・表示切替・パネル -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                    <!-- 記録中タイトル（記録中のみ表示・その場で変更可能） -->
                    <TextBox Text="{Binding RecordingTitle, UpdateSourceTrigger=PropertyChanged}"
                             Width="160" VerticalAlignment="Center" Margin="0,0,8,0"
                             Style="{StaticResource InputTextBoxStyle}" FontSize="12"
                             ToolTip="記録中のタイトル（停止時にこの内容で保存されます）"
                             Visibility="{Binding IsRecording, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- 記録ボタン -->
                    <Button Command="{Binding ToggleRecordingCommand}" BorderBrush="{DynamicResource DangerBrush}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                            </Style>
                        </Button.Style>
                        <Button.Template>
                             <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerSubtleBrush}"/>
                                    </Trigger>
                                     <DataTrigger Binding="{Binding IsRecording}" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsRecording}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="border" Property="Background" Value="{DynamicResource DangerDarkBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </MultiDataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                         <TextBlock Text="{Binding RecordingDurationText}" Width="140" TextAlignment="Center"/>
                    </Button>

                    <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                    <!-- 表示切替ドロップダウン -->
                    <ComboBox ItemsSource="{Binding ViewModeOptions}" SelectedItem="{Binding SelectedViewModeOption}"
                              DisplayMemberPath="Label" Width="124" VerticalAlignment="Center" ToolTip="表示モード"/>

                    <Border Style="{StaticResource ToolbarSeparatorStyle}"/>

                    <!-- メモ / 設定 -->
                    <ToggleButton Content="&#xE70B;" IsChecked="{Binding IsMemoPanelVisible}"
                                  Style="{StaticResource IconToggleButtonStyle}" ToolTip="メモ"
                                  Margin="0,0,2,0" VerticalAlignment="Center"/>

                    <ToggleButton Content="&#xE713;" IsChecked="{Binding IsSettingsPanelVisible}"
                                  Style="{StaticResource IconToggleButtonStyle}" ToolTip="設定"
                                  VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 定期予定リマインダー通知（開始時刻に達した予定ごとに1行表示） -->
        <ItemsControl ItemsSource="{Binding PendingReminders}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource PrimarySubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryBrush}"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13">
                                <Run Text="{Binding Title, Mode=OneWay}" FontWeight="Bold"/>
                                <Run Text=" の開始時刻です。記録を開始しますか？"/>
                            </TextBlock>
                            <Button Grid.Column="2" Content="記録開始"
                                    Command="{Binding DataContext.StartReminderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource PrimaryButtonStyle}" Padding="10,4" FontSize="12" Margin="0,0,8,0" Cursor="Hand"/>
                            <Button Grid.Column="3" Content="✕"
                                    Command="{Binding DataContext.DismissReminderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource IconButtonStyle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                    Width="24" Height="24" Cursor="Hand"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 自動記録開始の通知（数秒で自動的に消える） -->
        <Border Background="{DynamicResource PrimarySubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8"
                Visibility="{Binding HasAutoStartNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Text="{Binding AutoStartNotice}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
        </Border>

        <!-- 記録中の離席通知（記録は続けたまま、停止時に除外できることを伝える） -->
        <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="0,0,0,1" Padding="12,6"
                Visibility="{Binding ShowAwayBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="#B45309" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding AwayBannerText}" FontSize="12" VerticalAlignment="Center"
                           Foreground="#78350F"/>
            </StackPanel>
        </Border>

        <!--
            データ読み込みの異常通知（バックアップからの復元 / 読み込み失敗）。
            記録が失われたように見える状況で、原因と次の行動が分かるようにする。
        -->
        <Border Background="#FEF3C7" BorderBrush="#F59E0B" BorderThickness="0,0,0,2" Padding="12,8"
                Visibility="{Binding HasDataNotice, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                           Foreground="#B45309" VerticalAlignment="Top" Margin="0,1,10,0"/>

                <TextBlock Grid.Column="1" Text="{Binding DataNotice}" TextWrapping="Wrap"
                           Foreground="#78350F" FontSize="12" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Button Content="データフォルダを開く" Padding="10,4" Cursor="Hand" Margin="0,0,6,0"
                            Command="{Binding OpenDataFolderCommand}"/>
                    <Button Content="✕" Width="26" Padding="0,4" Cursor="Hand" ToolTip="この通知を閉じる"
                            Command="{Binding DismissDataNoticeCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        </StackPanel>

        <!-- ヘッダー行（曜日） + 終日イベントエリア -->
        <StackPanel Grid.Row="1" Background="{DynamicResource SurfaceBrush}" Visibility="{Binding IsMonthMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- スクロールバー幅分のスペーサー（スケジュール領域との列幅整合用） -->
                    <Border Grid.Column="2" Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                    
                    <!-- 日付ヘッダー -->
                    <controls:TransitioningContentControl Grid.Column="1" 
                                                          Content="{Binding CurrentDate}" 
                                                          TransitionDirection="{Binding TransitionDirection}"
                                                          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <controls:TransitioningContentControl.ContentTemplate>
                            <DataTemplate>
                                <ItemsControl Height="30">
                                    <ItemsControl.ItemsSource>
                                        <MultiBinding Converter="{StaticResource DateToVisibleDaysConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </ItemsControl.ItemsSource>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource DateToBackgroundBrushConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                                <TextBlock Text="{Binding StringFormat='MM/dd (ddd)'}" 
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" 
                                                           Language="ja-JP">
                                                    <TextBlock.Foreground>
                                                        <MultiBinding Converter="{StaticResource DayOfWeekToBrushConverter}">
                                                            <Binding />
                                                            <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                        </MultiBinding>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </controls:TransitioningContentControl.ContentTemplate>
                    </controls:TransitioningContentControl>
                </Grid>
            </Border>

            <!-- 終日イベントエリア -->
            <Grid MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- スクロールバー幅分のスペーサー（スケジュール領域との列幅整合用） -->
                <Border Grid.Column="2" Width="{x:Static SystemParameters.VerticalScrollBarWidth}"/>
                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource BackgroundBrush}">
                    <TextBlock Text="終日" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,4,8,4" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>
                <controls:TransitioningContentControl Grid.Column="1" 
                                                      Content="{Binding CurrentDate}" 
                                                      TransitionDirection="{Binding TransitionDirection}"
                                                      Height="{Binding AllDayPanelHeight}"
                                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <controls:TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding DataContext.AllDayItems, RelativeSource={RelativeSource AncestorType=Window}}" 
                                          Margin="0,2">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding BackgroundColor}" CornerRadius="6" Padding="6,2" Height="24" Opacity="0.95" BorderBrush="White" BorderThickness="1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ScheduleItem_MouseLeftButtonDown">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                            </Border.Effect>
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="編集" Click="EditMenuItem_Click"/>
                                                    <MenuItem Header="この内容で記録開始" Click="ResumeRecordingMenuItem_Click"/>
                                                    <MenuItem Header="削除" Click="DeleteMenuItem_Click"/>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <TextBlock Text="{Binding Title}" FontSize="12" TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}}"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Visibility">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPageVisibilityConverter}" FallbackValue="Collapsed">
                                                    <Binding Path="StartTime" />
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Canvas.Top" Value="{Binding ColumnIndex, Converter={StaticResource IndexToTopMarginConverter}}"/>
                                         <!-- X座標 (Canvas.Left) -->
                                        <Setter Property="Canvas.Left">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPagePositionConverter}">
                                                    <Binding Path="StartTime" />
                                                    <Binding Source="{StaticResource Zero}" /> <!-- ColumnIndex = 0 -->
                                                    <Binding Source="{StaticResource Zero}" /> <!-- MaxColumnIndex = 0 -->
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    <Binding Path="IsAllDay" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                        <!-- 幅 (Width) -->
                                        <Setter Property="Width">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource DateToPagePositionConverter}" ConverterParameter="WIDTH">
                                                    <Binding Path="StartTime" />
                                                    <Binding Source="{StaticResource Zero}" /> <!-- ColumnIndex = 0 -->
                                                    <Binding Source="{StaticResource Zero}" /> <!-- MaxColumnIndex = 0 -->
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                    <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                    <Binding Path="IsAllDay" />
                                                    <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                            </ItemsControl>
                        </DataTemplate>
                    </controls:TransitioningContentControl.ContentTemplate>
                </controls:TransitioningContentControl>
            </Grid>
            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"/>
        </StackPanel>

        <!-- スケジュール領域 -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Focusable="True" PreviewKeyDown="ScheduleView_PreviewKeyDown"
                      Visibility="{Binding IsMonthMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                      helpers:ScrollViewerHelper.EnableMiddleButtonScroll="True">
            <Grid Height="{Binding ScheduleGridHeight}" Background="{DynamicResource SurfaceBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 時刻ラベル -->
                <ItemsControl ItemsSource="{Binding TimeLabels}" Grid.Column="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                                <TextBlock Text="{Binding}" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,4,8,0" Foreground="{DynamicResource TextMutedBrush}" FontSize="12"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <controls:TransitioningContentControl Grid.Column="1" 
                                                      Content="{Binding CurrentDate}" 
                                                      TransitionDirection="{Binding TransitionDirection}"
                                                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <controls:TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <!-- Background=Transparent: 空白部分のクリック・ドラッグ（予定追加）をヒットテスト可能にする -->
                            <Grid Background="Transparent"
                                  MouseLeftButtonDown="ScheduleBackground_MouseLeftButtonDown"
                                  MouseMove="ScheduleBackground_MouseMove"
                                  MouseLeftButtonUp="ScheduleBackground_MouseLeftButtonUp">
                                <!-- 背景グリッド（縦：日付区切り） -->
                                <ItemsControl>
                                    <ItemsControl.ItemsSource>
                                        <MultiBinding Converter="{StaticResource DateToVisibleDaysConverter}">
                                            <Binding />
                                            <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                        </MultiBinding>
                                    </ItemsControl.ItemsSource>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 縦線 -->
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource DateToBackgroundBrushConverter}">
                                                        <Binding />
                                                        <Binding Path="DataContext.IsDarkMode" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Border.Background>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 背景グリッド（横：時間区切り） -->
                                <ItemsControl ItemsSource="{Binding DataContext.TimeLabels, RelativeSource={RelativeSource AncestorType=Window}}">
                                     <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="60" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                     <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Vertical"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <!-- スケジュールアイテム -->
                                <ItemsControl x:Name="ScheduleItemsControl" ItemsSource="{Binding DataContext.StandardItems, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <!-- ClipToBounds: 表示時間範囲外・日またぎのアイテムがグリッド外へはみ出して描画されるのを防ぐ -->
                                            <Canvas x:Name="ScheduleCanvas" ClipToBounds="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Visibility">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPageVisibilityConverter}" FallbackValue="Collapsed">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Canvas.Top">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                        <Binding Path="StartTime"/>
                                                        <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            
                                            <!-- X座標 (Canvas.Left) -->
                                            <Setter Property="Canvas.Left">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="ColumnIndex" />
                                                        <Binding Path="MaxColumnIndex" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Path="IsAllDay" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            <!-- 幅 (Width) -->
                                            <Setter Property="Width">
                                                <Setter.Value>
                                                    <MultiBinding Converter="{StaticResource DateToPagePositionConverter}" ConverterParameter="WIDTH">
                                                        <Binding Path="StartTime" />
                                                        <Binding Path="ColumnIndex" />
                                                        <Binding Path="MaxColumnIndex" />
                                                        <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/> <!-- CurrentDate from ItemsControl DataContext -->
                                                        <Binding Path="DataContext.CurrentViewMode" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        <Binding Path="IsAllDay" />
                                                        <Binding Path="DataContext.EnabledDaysOfWeek" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Setter.Value>
                                            </Setter>
                                            
                                            <!-- アニメーション用 -->
                
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid x:Name="ItemRoot" Cursor="Hand" MouseLeftButtonDown="ScheduleItem_MouseLeftButtonDown" Margin="1,0,1,0"
                                                  Height="{Binding DurationHours, Converter={StaticResource DurationToHeightConverter}, ConverterParameter=ADD_EXTENSION}"
                                                  ToolTip="{Binding Item.ToolTipText}"
                                                  ToolTipService.InitialShowDelay="250"
                                                  ToolTipService.ShowDuration="20000">
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="編集" Click="EditMenuItem_Click"/>
                                                    <MenuItem Header="この内容で記録開始" Click="ResumeRecordingMenuItem_Click"/>
                                                        <MenuItem Header="削除" Click="DeleteMenuItem_Click"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>

                                                <!-- 背景と形状 -->
                                                <Path x:Name="ItemShape" Fill="{Binding BackgroundColor}" Stroke="{DynamicResource BorderBrush}" StrokeThickness="1" Opacity="0.9">
                                                    <Path.Effect>
                                                         <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="2" Opacity="0.1"/>
                                                    </Path.Effect>
                                                    <Path.Data>
                                                        <MultiBinding Converter="{StaticResource LShapeGeometryConverter}">
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                        </MultiBinding>
                                                    </Path.Data>
                                                </Path>

                                                <!-- コンテンツ (下の15分部分(約15px)にはテキストが被らないようにマージン設定) -->
                                                <!-- 文字色は背景の輝度から決める（濃いカテゴリ色・ダークモードでも読めるように） -->
                                                <Border Padding="8,6" Margin="0,0,0,15" VerticalAlignment="Top">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}}"/>
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}, ConverterParameter=Muted}"/>
                                                        <!-- 日またぎで分割されたセグメントでも、元アイテムの本来の時間帯を表示する -->
                                                        <TextBlock FontSize="10" Margin="0,2,0,0"
                                                                   Foreground="{Binding BackgroundColor, Converter={StaticResource BrushToContrastTextConverter}, ConverterParameter=Muted}">
                                                            <Run Text="{Binding Item.StartTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding Item.EndTime, StringFormat=HH:mm, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <DataTemplate.Triggers>
                                                <!-- ホバー：不透明度と枠線を上げて、掴める対象だと分かるようにする -->
                                                <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemShape" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ItemShape" Property="Stroke" Value="{DynamicResource TextSecondaryBrush}"/>
                                                </Trigger>
                                                <!-- 選択中：太い枠線で示す（キーボード操作の現在位置） -->
                                                <DataTrigger Binding="{Binding Item.IsSelected}" Value="True">
                                                    <Setter TargetName="ItemShape" Property="Opacity" Value="1"/>
                                                    <Setter TargetName="ItemShape" Property="Stroke" Value="{DynamicResource TextPrimaryBrush}"/>
                                                    <Setter TargetName="ItemShape" Property="StrokeThickness" Value="2.5"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 現在時刻インジケーター -->
                                <Canvas ClipToBounds="True">
                                    <Border BorderBrush="{DynamicResource DangerBrush}" BorderThickness="0,2,0,0" Height="2" 
                                            Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}">
                                        <Canvas.Top>
                                            <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                <Binding Path="DataContext.CurrentTime" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Canvas.Top>
                                        <Border.Effect>
                                            <DropShadowEffect Color="{DynamicResource DangerColor}" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <!-- 現在時刻の赤丸 -->
                                    <Ellipse Fill="{DynamicResource DangerBrush}" Width="8" Height="8" Canvas.Left="-4"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Canvas.Top>
                                            <MultiBinding Converter="{StaticResource TimeToPositionConverter}">
                                                <Binding Path="DataContext.CurrentTime" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                <Binding Path="DataContext.DisplayStartHour" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                            </MultiBinding>
                                        </Canvas.Top>
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform Y="-4"/> <!-- ライン上に中心を合わせる -->
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Canvas>
                                
                            </Grid>
                        </DataTemplate>
                    </controls:TransitioningContentControl.ContentTemplate>
                </controls:TransitioningContentControl>
                
            </Grid>
        </ScrollViewer>

        <!-- 月表示用のカレンダー領域 -->
        <views:CalendarGridView Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource SurfaceBrush}"
                                Rows="6"
                                Visibility="{Binding IsMonthMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                controls:CalendarMonthCellControl.ItemClicked="MonthCell_ItemClicked"
                                controls:CalendarMonthCellControl.ItemRightClicked="MonthCell_ItemRightClicked"
                                controls:CalendarMonthCellControl.CellClicked="MonthCell_Clicked"/>

        <!-- スプリント表示用のカレンダー領域（週数に応じた可変グリッド） -->
        <views:CalendarGridView Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource SurfaceBrush}"
                                Rows="{Binding SprintWeekRows}"
                                Visibility="{Binding IsSprintMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                controls:CalendarMonthCellControl.ItemClicked="MonthCell_ItemClicked"
                                controls:CalendarMonthCellControl.ItemRightClicked="MonthCell_ItemRightClicked"
                                controls:CalendarMonthCellControl.CellClicked="MonthCell_Clicked"/>

        <!--
            スプリントタイムライン表示用の領域。

            時間軸は「1日 = TimelinePixelsPerDay ピクセル」の連続スケール。
            表示範囲を画面幅に押し込まないため、横スクロールとズーム（Ctrl+ホイール）で
            解像度を確保する。バーの幅は実際の時間量に比例し、時刻も丸めない。

            構成:
              行0  操作バー（行のまとめ方・ズーム）
              行1  ルーラー（上段=スプリント / 下段=ズーム連動の目盛り）
              行2  本体（外側=縦スクロール、内側=横スクロール）
              行3  密度ヒートバー（日別の記録時間。横スクロールに追従）
            ルーラーとヒートバーは本体とは別の ScrollViewer なので、
            コードビハインドで水平オフセットを同期している。
        -->
        <Grid Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource SurfaceBrush}"
              Visibility="{Binding IsSprintTimelineMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== 操作バー ===== -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="行" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox Width="110" VerticalAlignment="Center"
                              ItemsSource="{Binding TimelineGroupModeOptions}"
                              SelectedItem="{Binding SelectedTimelineGroupModeOption}"/>

                    <Rectangle Width="1" Margin="14,3" Fill="{DynamicResource BorderBrush}"/>

                    <TextBlock Text="範囲" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox Width="60" VerticalAlignment="Center"
                              ToolTip="表示するスプリント数"
                              ItemsSource="{Binding TimelineSpanOptions}"
                              SelectedItem="{Binding SelectedTimelineSpanOption}"/>
                    <TextBlock Text="スプリント" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <Rectangle Width="1" Margin="14,3" Fill="{DynamicResource BorderBrush}"/>

                    <TextBlock Text="表示幅" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ItemsControl ItemsSource="{Binding TimelineZoomPresets}" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Label}" Padding="9,3" Margin="0,0,4,0" Cursor="Hand"
                                        Command="{Binding DataContext.TimelineZoomPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="−" Width="26" Padding="0,3" Margin="10,0,3,0" Cursor="Hand"
                            ToolTip="ズームアウト" Command="{Binding TimelineZoomOutCommand}"/>
                    <Button Content="＋" Width="26" Padding="0,3" Margin="0,0,8,0" Cursor="Hand"
                            ToolTip="ズームイン" Command="{Binding TimelineZoomInCommand}"/>
                    <TextBlock Text="{Binding TimelineZoomText}" VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>

                    <TextBlock VerticalAlignment="Center" Margin="18,0,0,0" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Ctrl+ホイール ズーム / Shift+ホイール 横移動 / ←→ 選択 / Enter 編集 / F フィット / T 今日"/>
                </StackPanel>
            </Border>

            <!-- ===== ルーラー（上段: スプリント / 下段: ズーム連動の目盛り） ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左端ラベル列ぶんの余白（カテゴリ別モード以外は幅0） -->
                <Border Grid.Column="0" Width="{Binding TimelineLabelColumnWidth}"
                        Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1"/>

                <ScrollViewer Grid.Column="1" x:Name="TimelineHeaderScroll"
                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BackgroundBrush}">
                    <Grid Width="{Binding TimelineContentWidth}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="22"/>
                        </Grid.RowDefinitions>

                        <!-- 上段: スプリント名・期間・サマリー -->
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding TimelineSprintBands}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="0"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 幅はスプリントの実日数に比例する（長さの違いがそのまま出る） -->
                                    <Border Width="{Binding Width}" Height="30" Padding="6,0"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding RangeText}" FontSize="10" Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>

                                            <!-- 幅に余裕があるときだけ、合計時間と上位カテゴリを出す -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding ShowSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="{Binding SummaryText}" FontSize="10"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding TopCategoryText}" FontSize="10" Margin="6,0,0,0"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 下段: ズーム倍率に応じて 時刻 / 日 / 週 / 月 に切り替わる目盛り -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding TimelineTicks}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Top" Value="0"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="22">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="1,0,0,0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEmphasized}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Label}" FontSize="10" Margin="4,0,0,0"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ===== 本体 ===== -->
            <ScrollViewer Grid.Row="2" x:Name="TimelineVerticalScroll"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          Focusable="True" PreviewKeyDown="TimelineRoot_PreviewKeyDown"
                          helpers:ScrollViewerHelper.EnableMiddleButtonScroll="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- カテゴリ別モードの固定ラベル列（横スクロールしても残る） -->
                    <Border Grid.Column="0" Width="{Binding TimelineLabelColumnWidth}"
                            Height="{Binding TimelineContentHeight}"
                            Background="{DynamicResource BackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                        <ItemsControl ItemsSource="{Binding TimelineLaneGroups}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="0"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="149" Height="{Binding Height}" Padding="8,0"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Rectangle Width="4" Height="20" RadiusX="2" RadiusY="2"
                                                       Fill="{Binding Brush}" Margin="0,0,8,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12"
                                                           TextTrimming="CharacterEllipsis" MaxWidth="110"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}">
                                                    <Run Text="{Binding TotalText, Mode=OneWay}"/>
                                                    <Run Text=" ・ "/>
                                                    <Run Text="{Binding Count, Mode=OneWay}"/>
                                                    <Run Text="件"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <ScrollViewer Grid.Column="1" x:Name="TimelineBodyScroll"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  ScrollChanged="TimelineBodyScroll_ScrollChanged"
                                  PreviewMouseWheel="TimelineBodyScroll_PreviewMouseWheel">
                        <!-- ドラッグ操作の基準面。バーもこの座標系で位置を計算する -->
                        <Grid x:Name="TimelineSurface"
                              Width="{Binding TimelineContentWidth}" Height="{Binding TimelineContentHeight}"
                              Background="Transparent"
                              MouseLeftButtonDown="TimelineSurface_MouseLeftButtonDown"
                              MouseMove="TimelineSurface_MouseMove"
                              MouseLeftButtonUp="TimelineSurface_MouseLeftButtonUp">

                            <!-- 日単位の背景（土日・無効曜日のシェード、日/週の罫線、今日の強調） -->
                            <ItemsControl ItemsSource="{Binding TimelineDayColumns}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding Width}"
                                                Height="{Binding DataContext.TimelineContentHeight, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="Weekend">
                                                            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="Disabled">
                                                            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                                            <Setter Property="Opacity" Value="0.6"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="Today">
                                                            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ShowDayLine}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1,0,0,0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- スプリント境界 -->
                            <ItemsControl ItemsSource="{Binding TimelineSprintBands}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding Width}"
                                                Height="{Binding DataContext.TimelineContentHeight, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Background="Transparent"
                                                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1,0,0,0"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- カテゴリ別モードの行帯（交互に薄く塗って群の区切りを示す） -->
                            <ItemsControl ItemsSource="{Binding TimelineLaneGroups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="0"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Height="{Binding Height}"
                                                Width="{Binding DataContext.TimelineContentWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 予定バー -->
                            <ItemsControl ItemsSource="{Binding TimelineBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!--
                                            外側の Grid は「掴める幅」(HitWidth)。
                                            内側の Border は「実際の時間量に対応する幅」(DrawWidth)。
                                            両者を分けることで、見た目の正確さとクリックしやすさを両立する。
                                        -->
                                        <Grid x:Name="BarRoot" Width="{Binding HitWidth}" Height="{Binding Height}"
                                              Background="Transparent" Cursor="Hand"
                                              ToolTip="{Binding ToolTipText}"
                                              ToolTipService.InitialShowDelay="250"
                                              ToolTipService.ShowDuration="20000"
                                              MouseLeftButtonDown="TimelineBar_MouseLeftButtonDown">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="編集" Click="EditMenuItem_Click"/>
                                                    <MenuItem Header="この内容で記録開始" Click="ResumeRecordingMenuItem_Click"/>
                                                    <MenuItem Header="削除" Click="DeleteMenuItem_Click"/>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <Border x:Name="BarBody" HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Width="{Binding DrawWidth}" Height="{Binding Height}"
                                                    CornerRadius="3" BorderThickness="1"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    Background="{Binding Background}">
                                                <!-- 収まるときだけバー内にタイトルを描く -->
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12"
                                                           Margin="6,0" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding IsLabelInside, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                           Foreground="{Binding Background, Converter={StaticResource BrushToContrastTextConverter}}"/>
                                            </Border>

                                            <!-- 収まらないときはバーの右隣に出す（バーの幅は正しいまま保つ） -->
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       HorizontalAlignment="Left" VerticalAlignment="Center"
                                                       Margin="{Binding OutsideLabelMargin}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       Visibility="{Binding IsLabelInside, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                        </Grid>

                                        <DataTemplate.Triggers>
                                            <!-- ホバーは判定領域全体で反応させる（細いバーでも効くように） -->
                                            <Trigger SourceName="BarRoot" Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BarBody" Property="BorderBrush"
                                                        Value="{DynamicResource TextSecondaryBrush}"/>
                                            </Trigger>
                                            <!-- 選択中は太い外枠で示す（キーボード操作の現在位置） -->
                                            <DataTrigger Binding="{Binding Item.IsSelected}" Value="True">
                                                <Setter TargetName="BarBody" Property="BorderBrush"
                                                        Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter TargetName="BarBody" Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                            <!-- 検索中の非ヒットは減光してヒットを浮き立たせる -->
                                            <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                                <Setter TargetName="BarRoot" Property="Opacity" Value="0.2"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 範囲ドラッグ中のプレビュー（位置と幅はコードビハインドが設定する） -->
                            <Border x:Name="TimelineRangePreview" Visibility="Collapsed"
                                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                    Width="0" IsHitTestVisible="False"
                                    Background="{DynamicResource BorderBrush}" Opacity="0.35"
                                    BorderBrush="{DynamicResource TextPrimaryBrush}" BorderThickness="1"/>

                            <!-- 現在時刻ライン -->
                            <Grid HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="2"
                                  IsHitTestVisible="False"
                                  Margin="{Binding TimelineNowMargin}"
                                  Visibility="{Binding IsTimelineNowVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Rectangle Fill="#EF4444" Width="2" VerticalAlignment="Stretch"/>
                                <Border Background="#EF4444" CornerRadius="2" Padding="3,1"
                                        VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,0">
                                    <TextBlock Text="{Binding TimelineNowText}" FontSize="9" Foreground="White"/>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </ScrollViewer>

            <!-- 範囲外インジケータ（本体の左右端に重ねる） -->
            <Button Grid.Row="2" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,8,0,0"
                    Padding="8,3" Cursor="Hand" FontSize="11"
                    Content="{Binding TimelineOverflowBeforeText}"
                    ToolTip="表示範囲より前の記録へ移動"
                    Command="{Binding TimelineJumpOverflowCommand}" CommandParameter="before"
                    Visibility="{Binding HasTimelineOverflowBefore, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <Button Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,20,0"
                    Padding="8,3" Cursor="Hand" FontSize="11"
                    Content="{Binding TimelineOverflowAfterText}"
                    ToolTip="表示範囲より後の記録へ移動"
                    Command="{Binding TimelineJumpOverflowCommand}" CommandParameter="after"
                    Visibility="{Binding HasTimelineOverflowAfter, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- 空状態 -->
            <TextBlock Grid.Row="2" Text="この期間に記録はありません"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- ===== 密度ヒートバー（日別の記録時間。ズームアウト時の全体把握用） ===== -->
            <Grid Grid.Row="3" Background="{DynamicResource BackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="{Binding TimelineLabelColumnWidth}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,1,0">
                    <TextBlock Text="記録量" FontSize="10" VerticalAlignment="Center" Margin="8,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Border>

                <ScrollViewer Grid.Column="1" x:Name="TimelineDensityScroll"
                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
                        <ItemsControl ItemsSource="{Binding TimelineDensityBars}"
                                      Width="{Binding TimelineContentWidth}"
                                      Height="{Binding TimelineDensityHeight}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                    <Setter Property="Canvas.Bottom" Value="4"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding Width}" Height="{Binding BarHeight}"
                                            VerticalAlignment="Bottom" CornerRadius="1"
                                            Background="{DynamicResource TextSecondaryBrush}" Opacity="0.55"
                                            ToolTip="{Binding ToolTipText}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 統計表示用の領域 -->
        <Grid Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource SurfaceBrush}"
              Visibility="{Binding IsStatsMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" helpers:ScrollViewerHelper.EnableMiddleButtonScroll="True">
                <StackPanel Margin="24" MaxWidth="960">

                    <!-- 期間切替 + サマリー -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <RadioButton Content="週" Command="{Binding ChangeStatsPeriodCommand}" CommandParameter="Week"
                                         IsChecked="{Binding IsStatsWeekPeriod, Mode=OneWay}" GroupName="StatsPeriod"
                                         Style="{StaticResource SegmentedLeftStyle}"/>
                            <RadioButton Content="月" Command="{Binding ChangeStatsPeriodCommand}" CommandParameter="Month"
                                         IsChecked="{Binding IsStatsMonthPeriod, Mode=OneWay}" GroupName="StatsPeriod"
                                         Style="{StaticResource SegmentedMiddleStyle}"/>
                            <RadioButton Content="スプリント" Command="{Binding ChangeStatsPeriodCommand}" CommandParameter="Sprint"
                                         IsChecked="{Binding IsStatsSprintPeriod, Mode=OneWay}" GroupName="StatsPeriod"
                                         Style="{StaticResource SegmentedRightStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{Binding StatsSummaryText}" VerticalAlignment="Center"
                                   FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Grid>

                    <!-- データなし -->
                    <TextBlock Text="この期間に記録はありません（終日の予定は集計対象外です）"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="13" Margin="0,8,0,24"
                               Visibility="{Binding HasStatsData, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>

                    <!-- カテゴリ別作業時間 -->
                    <StackPanel Visibility="{Binding HasStatsData, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="カテゴリ別作業時間" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding StatsCategoryItems}" Margin="0,0,0,28">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="56"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                            <Border Width="14" Height="14" Background="{Binding Brush}" CornerRadius="3"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ProgressBar Grid.Column="1" Value="{Binding Hours, Mode=OneWay}" Maximum="{Binding MaxHours, Mode=OneWay}"
                                                     Height="18" Foreground="{Binding Brush}" Style="{StaticResource StatsBarStyle}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding HoursText}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding PercentText}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 日別の推移（積み上げ棒グラフ） -->
                        <TextBlock Text="日別の推移" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,0">
                            <ItemsControl ItemsSource="{Binding StatsDailyItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="1,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="16"/>
                                                <RowDefinition Height="180"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 合計時間ラベル -->
                                            <TextBlock Grid.Row="0" Text="{Binding TotalText}" FontSize="9"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            <!-- 積み上げバー -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Segments}" VerticalAlignment="Bottom" Margin="3,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Height="{Binding HeightPx}" Background="{Binding Brush}"
                                                                BorderBrush="{DynamicResource SurfaceBrush}" BorderThickness="0,0,0,1"
                                                                ToolTip="{Binding ToolTipText}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <!-- 日付ラベル -->
                                            <TextBlock Grid.Row="2" Text="{Binding Label}" FontSize="10" Margin="0,4,0,0"
                                                       HorizontalAlignment="Center" TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- メモパネル -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" 
                Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                ClipToBounds="True">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="400"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMemoPanelVisible}" Value="False">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="400" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Width="400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                </Grid.RowDefinitions>
                
                <!-- ヘッダー -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}" Padding="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="メモ (Markdown)" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Grid.Column="0"/>
                        
                        <!-- モード切替 -->
                        <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,20,0">
                             <RadioButton Content="編集" IsChecked="{Binding IsMemoEditMode}" GroupName="MemoMode"
                                          Style="{StaticResource SegmentedLeftStyle}"/>
                             <RadioButton Content="表示" IsChecked="{Binding IsMemoEditMode, Converter={StaticResource InverseBooleanConverter}}" GroupName="MemoMode"
                                          Style="{StaticResource SegmentedRightStyle}"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="×" Command="{Binding ToggleMemoPanelCommand}" 
                                Style="{StaticResource IconButtonStyle}"
                                Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}" Cursor="Hand" Width="24" Height="24"/>
                    </Grid>
                </Border>
                
                <!-- エディタ -->
                <TextBox Grid.Row="1" Text="{Binding MemoText, UpdateSourceTrigger=PropertyChanged}" 
                         AcceptsReturn="True" TextWrapping="Wrap" Padding="12" BorderThickness="0"
                         FontFamily="Consolas, Meiryo UI" FontSize="14" VerticalScrollBarVisibility="Auto" Background="Transparent"
                         Visibility="{Binding IsMemoEditMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- プレビュー -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12" Background="Transparent"
                              Visibility="{Binding IsMemoEditMode, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                              helpers:ScrollViewerHelper.EnableMiddleButtonScroll="True">
                    <markdig:MarkdownViewer Markdown="{Binding MemoText}"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 設定パネル (右スライドイン・オーバーレイ) -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" HorizontalAlignment="Right"
                Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                Panel.ZIndex="100" ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="-4" Opacity="0.1"/>
            </Border.Effect>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Width" Value="320"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsPanelVisible}" Value="False">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Width" To="320" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid Width="320">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                </Grid.RowDefinitions>
                
                <!-- ヘッダー -->
                <Border Grid.Row="0" Background="{DynamicResource BackgroundBrush}" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="設定" FontWeight="SemiBold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="✕" Command="{Binding ToggleSettingsPanelCommand}" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Style="{StaticResource IconButtonStyle}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Grid>
                </Border>
                
                <!-- コンテンツ（タブ切替 + 各タブ内は縦スクロール・セクション折りたたみ） -->
                <TabControl Grid.Row="1" Style="{StaticResource SettingsTabControlStyle}">

                <!-- タブ1: 一般（外観・表示設定） -->
                <TabItem Header="一般" Style="{StaticResource SettingsTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,4,24,24" Background="{DynamicResource SurfaceBrush}">
                    <!-- 外観設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="外観" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="ダークモード" Style="{StaticResource FieldLabelStyle}" Margin="0"/>
                            <TextBlock Text="暗い配色テーマを使用します" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>
                        <!-- トグルスイッチ -->
                        <ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkMode}" VerticalAlignment="Center"
                                      Width="44" Height="24" Padding="0" BorderThickness="0" Cursor="Hand">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid>
                                                    <Border x:Name="track" Width="44" Height="24" CornerRadius="12"
                                                            Background="{DynamicResource MutedBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                                    <Ellipse x:Name="thumb" Width="18" Height="18"
                                                             Fill="{DynamicResource TextMutedBrush}"
                                                             HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="track" Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                        <Setter TargetName="thumb" Property="Fill" Value="White"/>
                                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                        <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumb" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                    </Grid>
                    </Expander>

                    <!-- 表示設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="表示設定" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <StackPanel>
                    <!-- 表示時間範囲 -->
                    <Grid Margin="0,0,0,16" Visibility="{Binding IsTimeRangeSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="表示時間範囲" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding StartHourOptions}" SelectedItem="{Binding DisplayStartHour, UpdateSourceTrigger=PropertyChanged}"
                                      Width="70" FontSize="13" />
                            <TextBlock Text="～" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0" />
                            <ComboBox ItemsSource="{Binding EndHourOptions}" SelectedItem="{Binding DisplayEndHour, UpdateSourceTrigger=PropertyChanged}"
                                      Width="70" FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <!-- 時刻の刻み幅（ドラッグ操作で丸める単位） -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="時刻の刻み幅" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ComboBox ItemsSource="{Binding SnapMinutesOptions}"
                                      SelectedItem="{Binding SnapMinutes, UpdateSourceTrigger=PropertyChanged}"
                                      Width="70" FontSize="13"
                                      ToolTip="ドラッグでの移動・伸縮・範囲作成で時刻を丸める単位"/>
                            <TextBlock Text="分単位" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Grid>

                    <!-- 表示曜日 -->
                    <Grid Margin="0,0,0,16" Visibility="{Binding IsDayOfWeekSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" Text="表示曜日" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Top" Margin="0,4,16,0" />
                        
                        <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox Content="月" IsChecked="{Binding ShowMonday}" Margin="0,0,12,6" FontSize="13"/>
                            <CheckBox Content="火" IsChecked="{Binding ShowTuesday}" Margin="0,0,12,6" FontSize="13"/>
                            <CheckBox Content="水" IsChecked="{Binding ShowWednesday}" Margin="0,0,12,6" FontSize="13"/>
                            <CheckBox Content="木" IsChecked="{Binding ShowThursday}" Margin="0,0,12,6" FontSize="13"/>
                            <CheckBox Content="金" IsChecked="{Binding ShowFriday}" Margin="0,0,12,6" FontSize="13"/>
                            <CheckBox Content="土" IsChecked="{Binding ShowSaturday}" Margin="0,0,12,6" FontSize="13" Foreground="{DynamicResource PrimaryBrush}"/>
                            <CheckBox Content="日" IsChecked="{Binding ShowSunday}" Margin="0,0,12,6" FontSize="13" Foreground="{DynamicResource DangerBrush}"/>
                        </WrapPanel>
                    </Grid>
                    </StackPanel>
                    </Expander>

                    <!-- 離席・中断の検知 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="離席・中断の検知" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="記録中の無操作・スリープ・画面ロックを検知します。記録は自動では変更されず、停止したときに除外するかを確認します。"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="離席を検知する" Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <CheckBox Grid.Column="1" IsChecked="{Binding IsAwayDetectionEnabled}"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <Grid Margin="0,0,0,16"
                                  Visibility="{Binding IsAwayDetectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="離席とみなす時間" Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ComboBox ItemsSource="{Binding AwayThresholdOptions}"
                                              SelectedItem="{Binding AwayThresholdMinutes, UpdateSourceTrigger=PropertyChanged}"
                                              Width="70" FontSize="13"/>
                                    <TextBlock Text="分の無操作" VerticalAlignment="Center" Margin="8,0,0,0"
                                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <!-- 検知したときの扱い -->
                            <Grid Margin="0,0,0,6"
                                  Visibility="{Binding IsAwayDetectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="LabelG"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="検知したときの扱い" Style="{StaticResource FieldLabelStyle}"
                                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                                <ComboBox Grid.Column="1" HorizontalAlignment="Left" Width="180" FontSize="13"
                                          ItemsSource="{Binding AwayHandlingOptions}"
                                          SelectedItem="{Binding SelectedAwayHandlingOption}"/>
                            </Grid>

                            <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding IsAwayDetectionEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Text="「常に除外する」を選ぶと確認画面を出さずに離席分を差し引きます。差し引いた内容は通知され、Ctrl+Z で元に戻せます。"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
                </ScrollViewer>
                </TabItem>

                <!-- タブ2: 分類（カテゴリ・定型タイトル） -->
                <TabItem Header="分類" Style="{StaticResource SettingsTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,4,24,24" Background="{DynamicResource SurfaceBrush}">
                    <!-- カテゴリ設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="カテゴリ" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <StackPanel>
                    <TextBlock Text="色に名前を付けて分類できます（統計に反映）" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Categories}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 色選択 -->
                                    <ComboBox Grid.Column="0" Width="56" VerticalAlignment="Center" Margin="0,0,8,0"
                                              ItemsSource="{Binding DataContext.PaletteColors, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedValuePath="Code" SelectedValue="{Binding ColorCode}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="20" Height="14" Background="{Binding Brush}" CornerRadius="3"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                        ToolTip="{Binding Name}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <!-- 名前 -->
                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource InputTextBoxStyle}" FontSize="12" VerticalAlignment="Center"/>
                                    <!-- 削除 -->
                                    <Button Grid.Column="2" Content="✕" Margin="4,0,0,0"
                                            Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                            Width="24" Height="24" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="＋ カテゴリを追加" Command="{Binding AddCategoryCommand}"
                            Style="{StaticResource BaseButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    </StackPanel>
                    </Expander>

                    <!-- 定型タイトル設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="定型タイトル" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <StackPanel>
                    <TextBlock Text="タイトル入力欄の候補に常に表示されます" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding PinnedTitles}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Text, UpdateSourceTrigger=LostFocus}"
                                             Style="{StaticResource InputTextBoxStyle}" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="✕" Margin="4,0,0,0"
                                            Command="{Binding DataContext.DeletePinnedTitleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource IconButtonStyle}" Foreground="{DynamicResource TextSecondaryBrush}"
                                            Width="24" Height="24" Cursor="Hand"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="＋ 定型タイトルを追加" Command="{Binding AddPinnedTitleCommand}"
                            Style="{StaticResource BaseButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    </StackPanel>
                    </Expander>
                </StackPanel>
                </ScrollViewer>
                </TabItem>

                <!-- タブ3: 定期予定（ルーティン） -->
                <TabItem Header="定期予定" Style="{StaticResource SettingsTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,4,24,24" Background="{DynamicResource SurfaceBrush}">
                    <!-- 定期予定（ルーティン）設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="定期予定（ルーティン）" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <StackPanel>
                    <TextBlock Text="毎週決まった曜日・時刻の予定を自動生成します。記録の開始忘れ防止に使えます（開始時刻にリマインダー通知、または自動で記録開始）"
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Routines}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding DaysOfWeekDisplay, Mode=OneWay}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding TimeRangeDisplay, Mode=OneWay}"/>
                                            </TextBlock>
                                            <TextBlock Text="自動開始" FontSize="10" Foreground="{DynamicResource PrimaryBrush}" Margin="0,2,0,0"
                                                       Visibility="{Binding IsAutoStart, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            <TextBlock Text="無効" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"
                                                       Visibility="{Binding IsEnabled, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="編集"
                                                    Command="{Binding DataContext.EditRoutineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Padding="6,4" FontSize="11" Margin="0,0,4,0" Cursor="Hand"/>
                                            <Button Content="削除"
                                                    Command="{Binding DataContext.DeleteRoutineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButtonStyle}" Foreground="{DynamicResource DangerBrush}"
                                                    Padding="6,4" FontSize="11" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="＋ 定期予定を追加" Command="{Binding AddRoutineCommand}"
                            Style="{StaticResource BaseButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    </StackPanel>
                    </Expander>
                </StackPanel>
                </ScrollViewer>
                </TabItem>

                <!-- タブ4: スプリント -->
                <TabItem Header="スプリント" Style="{StaticResource SettingsTabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,4,24,24" Background="{DynamicResource SurfaceBrush}">
                    <!-- スプリント設定 -->
                    <Expander Style="{StaticResource SettingsExpanderStyle}" IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="スプリント設定 (手動)" Style="{StaticResource SettingsSectionHeaderStyle}"/>
                        </Expander.Header>
                    <StackPanel>
                        <!-- 手動スプリント一覧リスト -->
                        <ListBox ItemsSource="{Binding ManualSprints}" MaxHeight="120" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Background="Transparent" Margin="0,0,0,12" Focusable="False">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4,6"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Focusable" Value="False"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                                            <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0">
                                                <Run Text="{Binding StartDate, StringFormat='yyyy/MM/dd', Mode=OneWay}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndDate, StringFormat='MM/dd', Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="編集" 
                                                    Command="{Binding DataContext.EditManualSprintCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButtonStyle}" 
                                                    Padding="6,4" FontSize="11" Margin="0,0,4,0" Cursor="Hand"/>
                                            <Button Content="削除" 
                                                    Command="{Binding DataContext.DeleteManualSprintCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource GhostButtonStyle}" Foreground="{DynamicResource DangerBrush}" 
                                                    Padding="6,4" FontSize="11" Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- 追加フォームコントロール -->
                        <Grid Margin="0,0,0,10">
                            <!-- 追加ボタン -->
                            <Button Content="＋ スプリントを追加" 
                                    Command="{Binding ShowAddSprintFormCommand}"
                                    Visibility="{Binding IsAddSprintFormVisible, Converter={StaticResource InvertedBooleanToVisibilityConverter}}"
                                    Style="{StaticResource BaseButtonStyle}" HorizontalAlignment="Stretch"/>
                            
                            <!-- インライン追加フォーム -->
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Background="{DynamicResource BackgroundBrush}"
                                    Visibility="{Binding IsAddSprintFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding FormTitle}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                                    <TextBlock Text="スプリント名" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding NewSprintName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Style="{StaticResource InputTextBoxStyle}"/>
                                    
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="開始日" Style="{StaticResource FieldLabelStyle}"/>
                                            <DatePicker SelectedDate="{Binding NewSprintStartDate, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="終了日" Style="{StaticResource FieldLabelStyle}"/>
                                            <DatePicker SelectedDate="{Binding NewSprintEndDate, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="キャンセル" Command="{Binding HideAddSprintFormCommand}" Style="{StaticResource BaseButtonStyle}" Cursor="Hand"/>
                                        <Button Grid.Column="2" Content="保存" Command="{Binding SaveNewSprintCommand}" Style="{StaticResource PrimaryButtonStyle}" Cursor="Hand"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                    </Expander>
                </StackPanel>
                </ScrollViewer>
                </TabItem>

                </TabControl>

            </Grid>
        </Border>

    </Grid>
</Window>
