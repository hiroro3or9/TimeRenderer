<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Primary Colors (Blue based) -->
    <Color x:Key="PrimaryColor">#3B82F6</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <Color x:Key="PrimaryDarkColor">#2563EB</Color>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <Color x:Key="PrimaryLightColor">#60A5FA</Color>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <Color x:Key="PrimarySubtleColor">#EBF5FF</Color>
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource PrimarySubtleColor}"/>

    <!-- 出勤・退勤マーカー（予定の色・現在時刻の赤と衝突しない色を選ぶ） -->
    <Color x:Key="WorkStartColor">#0EA5E9</Color>
    <SolidColorBrush x:Key="WorkStartBrush" Color="{StaticResource WorkStartColor}"/>
    <Color x:Key="WorkEndColor">#7C3AED</Color>
    <SolidColorBrush x:Key="WorkEndBrush" Color="{StaticResource WorkEndColor}"/>

    <!-- Danger Colors (Red based) -->
    <Color x:Key="DangerColor">#EF4444</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <Color x:Key="DangerDarkColor">#DC2626</Color>
    <SolidColorBrush x:Key="DangerDarkBrush" Color="{StaticResource DangerDarkColor}"/>
    <Color x:Key="DangerSubtleColor">#FEF2F2</Color>
    <SolidColorBrush x:Key="DangerSubtleBrush" Color="{StaticResource DangerSubtleColor}"/>

    <!-- Neutrals -->
    <Color x:Key="BackgroundColor">#F8FAFC</Color> <!-- Slate 50 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    
    <Color x:Key="MutedBackgroundColor">#E2E8F0</Color> <!-- Slate 200 -->
    <SolidColorBrush x:Key="MutedBackgroundBrush" Color="{StaticResource MutedBackgroundColor}"/>
    
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>

    <Color x:Key="BorderColor">#E2E8F0</Color> <!-- Slate 200 -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <Color x:Key="TextPrimaryColor">#1E293B</Color> <!-- Slate 800 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>

    <Color x:Key="TextSecondaryColor">#64748B</Color> <!-- Slate 500 -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <Color x:Key="TextMutedColor">#94A3B8</Color> <!-- Slate 400 -->
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <!-- ホバー・押下・ハイライト用補助カラー (Light) -->
    <Color x:Key="HoverBackgroundColor">#F1F5F9</Color> <!-- Slate 100 -->
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>
    <Color x:Key="PressedBackgroundColor">#E2E8F0</Color> <!-- Slate 200 -->
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="{StaticResource PressedBackgroundColor}"/>
    <Color x:Key="HoverBorderColor">#CBD5E1</Color> <!-- Slate 300 -->
    <SolidColorBrush x:Key="HoverBorderBrush" Color="{StaticResource HoverBorderColor}"/>

    <!-- ScrollBar Colors -->
    <Color x:Key="ScrollBarThumbColor">#33000000</Color> <!-- Black with 20% opacity -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <Color x:Key="ScrollBarThumbHoverColor">#73000000</Color> <!-- Black with 45% opacity -->
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>

</ResourceDictionary>
