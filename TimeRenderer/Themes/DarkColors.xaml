<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors (Blue based) -->
    <Color x:Key="PrimaryColor">#60A5FA</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <Color x:Key="PrimaryDarkColor">#93C5FD</Color>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <Color x:Key="PrimaryLightColor">#3B82F6</Color>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <Color x:Key="PrimarySubtleColor">#1E3A5F</Color>
    <SolidColorBrush x:Key="PrimarySubtleBrush" Color="{StaticResource PrimarySubtleColor}"/>

    <!-- Danger Colors (Red based) -->
    <Color x:Key="DangerColor">#F87171</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <Color x:Key="DangerDarkColor">#FCA5A5</Color>
    <SolidColorBrush x:Key="DangerDarkBrush" Color="{StaticResource DangerDarkColor}"/>
    <Color x:Key="DangerSubtleColor">#2D1F1F</Color>
    <SolidColorBrush x:Key="DangerSubtleBrush" Color="{StaticResource DangerSubtleColor}"/>

    <!-- Neutrals (Dark Theme) -->
    <Color x:Key="BackgroundColor">#0F172A</Color> <!-- Slate 900 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>

    <Color x:Key="MutedBackgroundColor">#1E293B</Color> <!-- Slate 800 -->
    <SolidColorBrush x:Key="MutedBackgroundBrush" Color="{StaticResource MutedBackgroundColor}"/>

    <Color x:Key="SurfaceColor">#1E293B</Color> <!-- Slate 800 -->
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>

    <Color x:Key="BorderColor">#334155</Color> <!-- Slate 700 -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <Color x:Key="TextPrimaryColor">#F1F5F9</Color> <!-- Slate 100 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>

    <Color x:Key="TextSecondaryColor">#94A3B8</Color> <!-- Slate 400 -->
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <Color x:Key="TextMutedColor">#64748B</Color> <!-- Slate 500 -->
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <!-- ホバー・押下・ハイライト用補助カラー (Dark) -->
    <Color x:Key="HoverBackgroundColor">#334155</Color> <!-- Slate 700 -->
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>
    <Color x:Key="PressedBackgroundColor">#1E293B</Color> <!-- Slate 800 -->
    <SolidColorBrush x:Key="PressedBackgroundBrush" Color="{StaticResource PressedBackgroundColor}"/>
    <Color x:Key="HoverBorderColor">#475569</Color> <!-- Slate 600 -->
    <SolidColorBrush x:Key="HoverBorderBrush" Color="{StaticResource HoverBorderColor}"/>

</ResourceDictionary>
